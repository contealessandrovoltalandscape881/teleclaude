{
  "telegram": {
    "allowedUsers": [123456789]
  },
  "processes": {
    "ttlMinutes": 30,
    "maxConcurrent": 5,
    "claudePath": "claude",
    "defaultFlags": ["--dangerously-skip-permissions"]
  },
  "compaction": {
    "reserveTokens": 100000,
    "keepRecentTokens": 50000,
    "enabled": true
  },
  "memory": {
    "revisionIntervalMinutes": 60,
    "maxFileLines": 200,
    "deduplication": true,
    "enabled": true
  },
  "projectsRoot": "C:/Users/YourName/Projects",
  "templatesDir": "./templates",
  "whisper": {
    "enabled": false,
    "url": "http://localhost:9000/asr",
    "language": "ru"
  }
}
